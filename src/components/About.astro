---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-xl bg-surface-container-lowest" id="about">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <div class="grid lg:grid-cols-2 gap-lg items-center">
      <div class="space-y-md">
        <h2 class="font-headline-lg text-headline-lg text-slate-deep">
          {t("about.title")}
        </h2>
        <p class="font-body-md text-body-md text-secondary">{t("about.p1")}</p>
        <p class="font-body-md text-body-md text-secondary">{t("about.p2")}</p>
        <ul class="space-y-xs">
          <li class="flex items-center gap-xs font-label-md text-slate-deep">
            <span class="material-symbols-outlined text-action-orange">check_circle</span>
            {t("about.bullet1")}
          </li>
          <li class="flex items-center gap-xs font-label-md text-slate-deep">
            <span class="material-symbols-outlined text-action-orange">check_circle</span>
            {t("about.bullet2")}
          </li>
          <li class="flex items-center gap-xs font-label-md text-slate-deep">
            <span class="material-symbols-outlined text-action-orange">check_circle</span>
            {t("about.bullet3")}
          </li>
        </ul>
      </div>
      <div class="grid grid-cols-2 gap-md">
        <div
          class="aspect-square bg-surface-container rounded-2xl p-lg flex flex-col justify-center items-center text-center space-y-md border border-outline-variant"
        >
          <span
            class="material-symbols-outlined text-[48px] text-primary"
            style="font-variation-settings: 'FILL' 1">security</span
          >
          <h3 class="font-headline-md text-headline-md">{t("about.card1.title")}</h3>
          <p class="font-label-sm text-label-sm text-secondary">{t("about.card1.text")}</p>
        </div>
        <div
          class="aspect-square bg-slate-deep rounded-2xl p-lg flex flex-col justify-center items-center text-center space-y-md text-surface-white"
        >
          <span
            class="material-symbols-outlined text-[48px] text-action-orange"
            style="font-variation-settings: 'FILL' 1">visibility</span
          >
          <h3 class="font-headline-md text-headline-md">{t("about.card2.title")}</h3>
          <p class="font-label-sm text-label-sm opacity-80">{t("about.card2.text")}</p>
        </div>
        <div
          class="col-span-2 bg-primary-container rounded-2xl p-lg flex items-center justify-between text-on-primary-container"
        >
          <div class="space-y-xs">
            <h3 class="font-headline-md text-headline-md">{t("about.card3.title")}</h3>
            <p class="font-body-md text-body-md">{t("about.card3.text")}</p>
          </div>
          <span class="material-symbols-outlined text-[64px] opacity-20">handshake</span>
        </div>
      </div>
    </div>
  </div>
</section>
