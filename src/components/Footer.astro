---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<section class="py-lg bg-surface-container-high border-y border-outline-variant">
  <div class="max-w-container-max mx-auto px-md md:px-lg grid md:grid-cols-3 gap-lg">
    <div class="space-y-xs">
      <h4 class="font-headline-md text-slate-deep">Lasa Trans s.r.o.</h4>
      <p class="font-body-md opacity-70">{t("footer.tagline")}</p>
    </div>
    <div class="space-y-xs">
      <div class="font-label-md font-bold">{t("footer.legalTitle")}</div>
      <div class="font-body-md text-secondary">{t("footer.legalIco")}: 29587875</div>
      <div class="font-body-md text-secondary">{t("footer.legalJednatel")}: Aliaksei Shyrokau</div>
    </div>
    <div class="space-y-xs">
      <div class="font-label-md font-bold">{t("footer.addressTitle")}</div>
      <div class="font-body-md text-secondary">{t("footer.address")}</div>
    </div>
  </div>
</section>

<footer class="bg-slate-deep text-primary-fixed-dim pt-xl pb-lg">
  <div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-gutter px-md md:px-lg max-w-container-max mx-auto py-lg"
  >
    <div class="space-y-md">
      <img src="/assets/logo.svg" alt="Lasa Trans" class="h-10 w-auto brightness-0 invert" />
      <p class="font-body-md opacity-70">{t("footer.slogan")}</p>
    </div>
    <div>
      <h4 class="font-label-md font-bold text-surface-white mb-lg uppercase tracking-widest">
        {t("footer.servicesTitle")}
      </h4>
      <ul class="space-y-md text-secondary-fixed-dim/70">
        <li><a class="hover:text-action-orange" href="#services">{t("footer.services1")}</a></li>
        <li><a class="hover:text-action-orange" href="#services">{t("footer.services2")}</a></li>
        <li><a class="hover:text-action-orange" href="#services">{t("footer.services3")}</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-label-md font-bold text-surface-white mb-lg uppercase tracking-widest">
        {t("footer.infoTitle")}
      </h4>
      <ul class="space-y-md text-secondary-fixed-dim/70">
        <li><a class="hover:text-action-orange" href="#about">{t("footer.info1")}</a></li>
        <li><a class="hover:text-action-orange" href="#destinations">{t("footer.info2")}</a></li>
        <li><a class="hover:text-action-orange" href="#why-us">{t("footer.info3")}</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-label-md font-bold text-surface-white mb-lg uppercase tracking-widest">
        {t("footer.contactsTitle")}
      </h4>
      <ul class="space-y-md text-secondary-fixed-dim/70">
        <li>{t("footer.addressShort")}</li>
        <li><a class="hover:text-action-orange" href="tel:+420777761570">+420 777 761 570</a></li>
        <li><a class="hover:text-action-orange" href="mailto:lasatrans2026@gmail.com">lasatrans2026@gmail.com</a></li>
      </ul>
    </div>
  </div>
  <div
    class="max-w-container-max mx-auto px-md md:px-lg py-md border-t border-slate-muted mt-xl flex flex-col md:flex-row justify-between items-center gap-md"
  >
    <p class="font-label-sm opacity-50">© {year} {t("footer.copyright")}</p>
  </div>
</footer>
