---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const stats = [
  { value: "10,000+", label: t("stats.s1.label") },
  { value: "98%", label: t("stats.s2.label") },
  { value: "500+", label: t("stats.s3.label") },
  { value: "6+", label: t("stats.s4.label") },
];
---

<section class="py-lg bg-slate-deep text-surface-white overflow-hidden relative">
  <div class="max-w-container-max mx-auto px-md md:px-lg relative z-10">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-lg text-center">
      {
        stats.map((s) => (
          <div class="space-y-xs">
            <div class="font-display-lg text-display-lg text-action-orange">{s.value}</div>
            <p class="font-label-md text-label-md opacity-70">{s.label}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
