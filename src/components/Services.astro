---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    title: t("services.s1.title"),
    text: t("services.s1.text"),
    img: "/assets/images/service-ftl.jpg",
    alt: t("services.s1.alt"),
  },
  {
    title: t("services.s2.title"),
    text: t("services.s2.text"),
    img: "/assets/images/service-expedition.jpg",
    alt: t("services.s2.alt"),
  },
  {
    title: t("services.s3.title"),
    text: t("services.s3.text"),
    img: "/assets/images/service-express.jpg",
    alt: t("services.s3.alt"),
  },
];
---

<section class="py-xl" id="services">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <h2 class="font-headline-lg text-headline-lg text-slate-deep mb-lg text-center">
      {t("services.title")}
    </h2>
    <div class="grid md:grid-cols-3 gap-lg">
      {
        services.map((s) => (
          <article class="group bg-surface-white rounded-2xl overflow-hidden border border-outline-variant shadow-sm hover:shadow-lg transition-all">
            <div class="h-48 bg-slate-deep overflow-hidden">
              <img
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                alt={s.alt}
                src={s.img}
                loading="lazy"
              />
            </div>
            <div class="p-lg space-y-md">
              <h3 class="font-headline-md text-headline-md text-slate-deep">{s.title}</h3>
              <p class="font-body-md text-body-md text-secondary">{s.text}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
