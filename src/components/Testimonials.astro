---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="py-xl bg-surface-container">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <h2 class="font-headline-lg text-headline-lg text-slate-deep mb-lg text-center">
      {t("test.title")}
    </h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-md">
      <blockquote class="bg-surface-white p-lg rounded-2xl border border-outline-variant relative">
        <p class="font-body-md text-body-md text-secondary mb-lg italic">{t("test.q1.text")}</p>
        <footer class="font-label-md text-slate-deep">{t("test.q1.author")}</footer>
      </blockquote>
      <blockquote class="bg-surface-white p-lg rounded-2xl border border-outline-variant relative">
        <p class="font-body-md text-body-md text-secondary mb-lg italic">{t("test.q2.text")}</p>
        <footer class="font-label-md text-slate-deep">{t("test.q2.author")}</footer>
      </blockquote>
      <blockquote
        class="bg-surface-white p-lg rounded-2xl border border-outline-variant relative hidden lg:block"
      >
        <p class="font-body-md text-body-md text-secondary mb-lg italic">{t("test.q3.text")}</p>
        <footer class="font-label-md text-slate-deep">{t("test.q3.author")}</footer>
      </blockquote>
    </div>
  </div>
</section>
