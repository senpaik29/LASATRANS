---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const thanksPath = lang === "cs" ? "/thank-you/" : "/en/thank-you/";
---

<section class="py-xl bg-slate-deep text-surface-white" id="quote">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <div class="grid lg:grid-cols-2 gap-xl">
      <div class="space-y-lg">
        <h2 class="font-display-lg text-display-lg">{t("quote.title")}</h2>
        <p class="font-body-lg text-body-lg text-surface-variant">{t("quote.subtitle")}</p>
        <div class="space-y-md">
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 rounded-full bg-action-orange/20 flex items-center justify-center text-action-orange">
              <span class="material-symbols-outlined">call</span>
            </div>
            <div>
              <div class="font-label-sm opacity-70">{t("quote.phoneLabel")}</div>
              <a class="font-body-lg hover:text-action-orange transition-colors" href="tel:+420777761570">+420 777 761 570</a>
            </div>
          </div>
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 rounded-full bg-action-orange/20 flex items-center justify-center text-action-orange">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <div>
              <div class="font-label-sm opacity-70">{t("quote.emailLabel")}</div>
              <a class="font-body-lg hover:text-action-orange transition-colors" href="mailto:lasatrans2026@gmail.com">lasatrans2026@gmail.com</a>
            </div>
          </div>
        </div>
      </div>
      <form
        class="bg-surface-white p-lg rounded-3xl text-on-surface space-y-md"
        id="quote-form"
        action="https://formsubmit.co/ajax/lasatrans2026@gmail.com"
        method="POST"
        data-thanks-url={thanksPath}
      >
        <input type="hidden" name="_subject" value={t("quote.form.subject")} />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_language" value={lang} />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="name">{t("quote.form.name")}</label>
            <input
              id="name"
              name="name"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder={t("quote.form.namePlaceholder")}
              type="text"
              required
            />
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="email">{t("quote.emailLabel")}</label>
            <input
              id="email"
              name="email"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder={t("quote.form.emailPlaceholder")}
              type="email"
              required
            />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="phone">{t("quote.form.phone")}</label>
            <input
              id="phone"
              name="phone"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder={t("quote.form.phonePlaceholder")}
              type="tel"
            />
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="cargo">{t("quote.form.cargo")}</label>
            <select
              id="cargo"
              name="cargo"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            >
              <option>{t("quote.form.cargoOpt1")}</option>
              <option>{t("quote.form.cargoOpt2")}</option>
              <option>{t("quote.form.cargoOpt3")}</option>
              <option>{t("quote.form.cargoOpt4")}</option>
              <option>{t("quote.form.cargoOpt5")}</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="pickup_from">{t("quote.form.pickupFrom")}</label>
            <div class="relative">
              <input
                id="pickup_from"
                name="pickup_from"
                class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm pr-10"
                type="text"
                inputmode="numeric"
                placeholder={t("quote.form.datePlaceholder")}
                pattern={"\\d{2}/\\d{2}/\\d{4}"}
                maxlength="10"
                autocomplete="off"
                data-date-input
              />
              <div class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 flex items-center justify-center text-secondary">
                <input
                  type="date"
                  class="absolute inset-0 opacity-0 cursor-pointer"
                  aria-label={t("quote.form.datePickerLabel")}
                  data-date-picker-for="pickup_from"
                />
                <span class="material-symbols-outlined pointer-events-none">calendar_month</span>
              </div>
            </div>
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="pickup_to">{t("quote.form.pickupTo")}</label>
            <div class="relative">
              <input
                id="pickup_to"
                name="pickup_to"
                class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm pr-10"
                type="text"
                inputmode="numeric"
                placeholder={t("quote.form.datePlaceholder")}
                pattern={"\\d{2}/\\d{2}/\\d{4}"}
                maxlength="10"
                autocomplete="off"
                data-date-input
              />
              <div class="absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 flex items-center justify-center text-secondary">
                <input
                  type="date"
                  class="absolute inset-0 opacity-0 cursor-pointer"
                  aria-label={t("quote.form.datePickerLabel")}
                  data-date-picker-for="pickup_to"
                />
                <span class="material-symbols-outlined pointer-events-none">calendar_month</span>
              </div>
            </div>
          </div>
        </div>
        <div>
          <label class="block font-label-md mb-xs" for="route">{t("quote.form.route")}</label>
          <input
            id="route"
            name="route"
            class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            placeholder={t("quote.form.routePlaceholder")}
            type="text"
          />
        </div>
        <div>
          <label class="block font-label-md mb-xs" for="notes">{t("quote.form.notes")}</label>
          <textarea
            id="notes"
            name="notes"
            class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            placeholder={t("quote.form.notesPlaceholder")}
            rows="3"></textarea>
        </div>
        <button
          class="w-full py-md bg-action-orange text-white font-bold rounded-xl hover:bg-opacity-90 transition-all flex justify-center items-center gap-xs disabled:opacity-60"
          type="submit"
          id="quote-submit"
        >
          <span>{t("quote.form.submit")}</span>
          <span class="material-symbols-outlined">send</span>
        </button>
        <p
          id="quote-error"
          class="hidden font-label-md text-center text-red-700 bg-red-50 border border-red-200 rounded-xl py-sm"
        >
          {t("quote.form.error")}
        </p>
        <p class="font-label-sm text-secondary text-center">
          {t("quote.form.privacy")}
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  const errorEl = document.getElementById("quote-error");
  const submitBtn = document.getElementById("quote-submit") as HTMLButtonElement | null;

  document.querySelectorAll<HTMLInputElement>("input[data-date-input]").forEach((el) => {
    el.addEventListener("input", () => {
      const digits = el.value.replace(/\D/g, "").slice(0, 8);
      let v = digits;
      if (digits.length >= 5) {
        v = `${digits.slice(0, 2)}/${digits.slice(2, 4)}/${digits.slice(4)}`;
      } else if (digits.length >= 3) {
        v = `${digits.slice(0, 2)}/${digits.slice(2)}`;
      }
      el.value = v;
    });
  });

  document.querySelectorAll<HTMLInputElement>("input[data-date-picker-for]").forEach((picker) => {
    picker.addEventListener("change", () => {
      const id = picker.getAttribute("data-date-picker-for");
      if (!id || !picker.value) return;
      const target = document.getElementById(id) as HTMLInputElement | null;
      if (!target) return;
      const [y, m, d] = picker.value.split("-");
      target.value = `${d}/${m}/${y}`;
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !submitBtn) return;

    const thanksUrl = form.dataset.thanksUrl ?? "/thank-you/";
    errorEl?.classList.add("hidden");
    submitBtn.disabled = true;

    try {
      const res = await fetch(form.action, {
        method: "POST",
        headers: { Accept: "application/json" },
        body: new FormData(form),
      });
      const data = await res.json().catch(() => ({}));
      if (res.ok && (data.success === "true" || data.success === true)) {
        window.location.href = thanksUrl;
        return;
      }
      errorEl?.classList.remove("hidden");
    } catch {
      errorEl?.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
