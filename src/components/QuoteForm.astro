---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "https://lasatrans.cz";
const thanksPath = lang === "cs" ? "/thank-you/" : "/en/thank-you/";
const nextUrl = `${siteOrigin}${thanksPath}`;
---

<section class="py-xl bg-slate-deep text-surface-white" id="quote">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <div class="grid lg:grid-cols-2 gap-xl">
      <div class="space-y-lg">
        <h2 class="font-display-lg text-display-lg">{t("quote.title")}</h2>
        <p class="font-body-lg text-body-lg text-surface-variant">{t("quote.subtitle")}</p>
        <div class="space-y-md">
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 rounded-full bg-action-orange/20 flex items-center justify-center text-action-orange">
              <span class="material-symbols-outlined">call</span>
            </div>
            <div>
              <div class="font-label-sm opacity-70">{t("quote.phoneLabel")}</div>
              <a class="font-body-lg hover:text-action-orange transition-colors" href="tel:+420777761570">+420 777 761 570</a>
            </div>
          </div>
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 rounded-full bg-action-orange/20 flex items-center justify-center text-action-orange">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <div>
              <div class="font-label-sm opacity-70">{t("quote.emailLabel")}</div>
              <a class="font-body-lg hover:text-action-orange transition-colors" href="mailto:lasatrans2026@gmail.com">lasatrans2026@gmail.com</a>
            </div>
          </div>
        </div>
      </div>
      <form
        class="bg-surface-white p-lg rounded-3xl text-on-surface space-y-md"
        id="quote-form"
        action="https://formsubmit.co/lasatrans2026@gmail.com"
        method="POST"
      >
        <input type="hidden" name="_subject" value={t("quote.form.subject")} />
        <input type="hidden" name="_template" value="table" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_language" value={lang} />
        <input type="hidden" name="_next" value={nextUrl} />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="name">{t("quote.form.name")}</label>
            <input
              id="name"
              name="name"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder={t("quote.form.namePlaceholder")}
              type="text"
              required
            />
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="email">{t("quote.emailLabel")}</label>
            <input
              id="email"
              name="email"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder={t("quote.form.emailPlaceholder")}
              type="email"
              required
            />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="phone">{t("quote.form.phone")}</label>
            <input
              id="phone"
              name="phone"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder={t("quote.form.phonePlaceholder")}
              type="tel"
            />
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="cargo">{t("quote.form.cargo")}</label>
            <select
              id="cargo"
              name="cargo"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            >
              <option>{t("quote.form.cargoOpt1")}</option>
              <option>{t("quote.form.cargoOpt2")}</option>
              <option>{t("quote.form.cargoOpt3")}</option>
              <option>{t("quote.form.cargoOpt4")}</option>
              <option>{t("quote.form.cargoOpt5")}</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block font-label-md mb-xs" for="route">{t("quote.form.route")}</label>
          <input
            id="route"
            name="route"
            class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            placeholder={t("quote.form.routePlaceholder")}
            type="text"
          />
        </div>
        <div>
          <label class="block font-label-md mb-xs" for="notes">{t("quote.form.notes")}</label>
          <textarea
            id="notes"
            name="notes"
            class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            placeholder={t("quote.form.notesPlaceholder")}
            rows="3"></textarea>
        </div>
        <button
          class="w-full py-md bg-action-orange text-white font-bold rounded-xl hover:bg-opacity-90 transition-all flex justify-center items-center gap-xs"
          type="submit"
        >
          {t("quote.form.submit")}
          <span class="material-symbols-outlined">send</span>
        </button>
        <p class="font-label-sm text-secondary text-center">
          {t("quote.form.privacy")}
        </p>
      </form>
    </div>
  </div>
</section>
