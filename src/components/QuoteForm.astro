---
---

<section class="py-xl bg-slate-deep text-surface-white" id="quote">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <div class="grid lg:grid-cols-2 gap-xl">
      <div class="space-y-lg">
        <h2 class="font-display-lg text-display-lg">Запросить коммерческое предложение</h2>
        <p class="font-body-lg text-body-lg text-surface-variant">
          Заполните форму — специалист свяжется с вами в течение 15 минут.
        </p>
        <div class="space-y-md">
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 rounded-full bg-action-orange/20 flex items-center justify-center text-action-orange">
              <span class="material-symbols-outlined">call</span>
            </div>
            <div>
              <div class="font-label-sm opacity-70">Телефон</div>
              <div class="font-body-lg">+420 777 761 570</div>
            </div>
          </div>
          <div class="flex items-center gap-md">
            <div class="w-10 h-10 rounded-full bg-action-orange/20 flex items-center justify-center text-action-orange">
              <span class="material-symbols-outlined">mail</span>
            </div>
            <div>
              <div class="font-label-sm opacity-70">Email</div>
              <div class="font-body-lg">lasatrans@gmail.com</div>
            </div>
          </div>
        </div>
      </div>
      <form
        class="bg-surface-white p-lg rounded-3xl text-on-surface space-y-md"
        id="quote-form"
      >
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="name">Имя</label>
            <input
              id="name"
              name="name"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder="Иван Иванов"
              type="text"
              required
            />
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="email">Email</label>
            <input
              id="email"
              name="email"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder="example@mail.com"
              type="email"
              required
            />
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md">
          <div>
            <label class="block font-label-md mb-xs" for="phone">Телефон</label>
            <input
              id="phone"
              name="phone"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
              placeholder="+420 000 000 000"
              type="tel"
            />
          </div>
          <div>
            <label class="block font-label-md mb-xs" for="cargo">Тип груза</label>
            <select
              id="cargo"
              name="cargo"
              class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            >
              <option>Обычный груз</option>
              <option>Сборный груз (LTL)</option>
              <option>Полная машина (FTL)</option>
              <option>Опасный груз (ADR)</option>
            </select>
          </div>
        </div>
        <div>
          <label class="block font-label-md mb-xs" for="route">Маршрут</label>
          <input
            id="route"
            name="route"
            class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            placeholder="Прага — Берлин"
            type="text"
          />
        </div>
        <div>
          <label class="block font-label-md mb-xs" for="notes">Дополнительно</label>
          <textarea
            id="notes"
            name="notes"
            class="w-full border border-outline-variant rounded-xl focus:ring-primary focus:border-primary px-md py-sm"
            placeholder="Габариты, вес, дата..."
            rows="3"></textarea>
        </div>
        <button
          class="w-full py-md bg-action-orange text-white font-bold rounded-xl hover:bg-opacity-90 transition-all flex justify-center items-center gap-xs"
          type="submit"
        >
          Отправить запрос
          <span class="material-symbols-outlined">send</span>
        </button>
        <p class="font-label-sm text-secondary text-center">
          Нажимая кнопку, вы соглашаетесь с политикой конфиденциальности.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    alert("Спасибо! Заявка принята.");
    form.reset();
  });
</script>
