---
const EU_COUNTRIES = [
  "BE","BG","CZ","DK","DE","EE","IE","GR","ES","FR","HR","IT","CY","LV",
  "LT","LU","HU","MT","NL","AT","PL","PT","RO","SI","SK","FI","SE",
];
---

<section class="py-xl bg-surface-container-low" id="destinations">
  <div class="max-w-container-max mx-auto px-md md:px-lg">
    <div class="flex flex-col md:flex-row justify-between items-end mb-lg gap-md">
      <div class="space-y-xs">
        <h2 class="font-headline-lg text-headline-lg text-slate-deep">География перевозок</h2>
        <p class="font-body-md text-body-md text-secondary">
          Регулярные рейсы по востребованным направлениям Европы
        </p>
      </div>
      <div class="flex gap-xs items-center">
        <span class="material-symbols-outlined text-primary">public</span>
        <span class="font-label-md font-bold text-primary uppercase tracking-widest">EU Network</span>
      </div>
    </div>
    <div id="countries-grid" class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-md">
      {
        EU_COUNTRIES.map((code) => (
          <div
            class="bg-surface-white p-md rounded-xl border border-outline-variant flex flex-col items-center gap-xs hover:border-primary transition-colors"
            title={code}
          >
            <img
              src={`https://flagcdn.com/w40/${code.toLowerCase()}.png`}
              width="40"
              height="30"
              alt={code}
              class="rounded-sm object-cover"
              loading="lazy"
            />
            <span class="font-label-md">{code}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>
